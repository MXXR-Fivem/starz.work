{
  "name": "starz-backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node -r ts-node/register/transpile-only src/server.ts\"",
    "start": "node -r ts-node/register/transpile-only src/server.ts",
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "audit": "npm audit --audit-level=moderate",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "jest --runInBand --testMatch \"<rootDir>/tests/unit/**/*.test.ts\"",
    "test:smoke": "jest --runInBand --testMatch \"<rootDir>/tests/integration/**/*.test.ts\"",
    "test:db:prepare": "node -r ts-node/register scripts/prepare-test-db.ts",
    "test:db": "npm run test:db:prepare && JEST_DB_TEST=true jest --runInBand --testMatch \"<rootDir>/tests/integration-db/**/*.test.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.2",
    "nodemailer": "^8.0.7",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
