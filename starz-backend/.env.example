NODE_ENV=development
PORT=3001
CORS_ALLOWED_ORIGINS=https://starz.work,https://api.starz.work

JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_COOKIE_SAME_SITE=lax
REFRESH_TOKEN_COOKIE_DOMAIN=
SWAGGER_FAVICON_URL=
SWAGGER_ENABLED=true

WLD_SYNC_ENABLED=false
WLD_API_URL=https://epi-api.welovedevs.com/v1
WLD_API_KEY=
WLD_SYNC_INTERVAL_MINUTES=10
WLD_SYNC_PAGE_SIZE=100
WLD_SYNC_QUERY=
WLD_API_MIN_DELAY_MS=1200
WLD_MAX_429_RETRIES=6

GEOCODING_URL=https://nominatim.openstreetmap.org/search
GEOCODING_COUNTRY_CODES=fr
GEOCODING_DEFAULT_RADIUS_KM=10
GEOCODING_TIMEOUT_MS=5000
GEOCODING_USER_AGENT=starz-work-backend/1.0

AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_REGISTER_MAX=5
AUTH_RATE_LIMIT_LOGIN_MAX=10
AUTH_RATE_LIMIT_REFRESH_MAX=20
AUTH_RATE_LIMIT_OAUTH_MAX=20
AUTH_RATE_LIMIT_ACTION_MAX=10

EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
RESET_PASSWORD_EXPIRES_IN=30m
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password
AUTH_DEBUG_TOKENS=false

UPLOAD_DIR=uploads
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=100kb
URLENCODED_PARAMETER_LIMIT=100
TRUST_PROXY=
PROFILE_PHOTO_MAX_BYTES=5242880
CV_MAX_BYTES=10485760

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/auth/callback/google,http://localhost:3000/auth/callback/github,http://localhost:3000/auth/callback/linkedin,http://localhost:3000/profile/oauth/google,http://localhost:3000/profile/oauth/github,http://localhost:3000/profile/oauth/linkedin

DB_HOST=localhost
DB_PORT=3307
DB_USER=app
DB_PASSWORD=app
DB_NAME=job_aggregator

DB_WAIT_FOR_CONNECTIONS=true
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
